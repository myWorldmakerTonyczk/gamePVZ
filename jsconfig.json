{
    "compilerOptions": {
        "paths": {
            "@core/*":   ["./Service/core/*"],
            "@entity/*": ["./Service/Entity/*"],
            "@system/*": ["./Service/system/*"],
            "@input/*":  ["./Service/Input/*"],
            "@utils/*":   ["./Service/Utils/*"],
            "@overlay/*": ["./Service/OverLay/*"],
            "@resource/*": ["./Service/Resource/*"],
            "@assets/*": ["./assets/*"],
            "@animation/*": ["./Service/Animation/*"],
            "@service/*": ["./Service/*"]
            
        }
    },
    "include": ["Service/**/*.js", "main.js", "level/**/*.js"]
}
